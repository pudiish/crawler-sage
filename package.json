{
  "name": "crawler-sage",
  "displayName": "Crawler Sage",
  "description": "Instant codebase context for AI agents — Repomix + Tree-sitter compression with interactive tree visualization",
  "version": "2.0.1",
  "publisher": "pudiish",
  "license": "MIT",
  "icon": "assets/712d070f4f6039f17137ac4f7abaa68b.jpg",
  "repository": {
    "type": "git",
    "url": "https://github.com/pudiish/crawler-sage"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Programming Languages"
  ],
  "keywords": [
    "ai",
    "context",
    "repomix",
    "tree-sitter",
    "copilot",
    "cursor",
    "codebase",
    "agent",
    "llm"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "crawlerSage.generate",
        "title": "Generate Context",
        "category": "Crawler Sage",
        "icon": "$(play)"
      },
      {
        "command": "crawlerSage.toggleWatch",
        "title": "Toggle File Watcher",
        "category": "Crawler Sage",
        "icon": "$(eye)"
      },
      {
        "command": "crawlerSage.openContext",
        "title": "Open Context File",
        "category": "Crawler Sage",
        "icon": "$(file)"
      },
      {
        "command": "crawlerSage.openRawOutput",
        "title": "Open Raw Repomix Output",
        "category": "Crawler Sage",
        "icon": "$(code)"
      },
      {
        "command": "crawlerSage.viewTree",
        "title": "Visualize Codebase Tree",
        "category": "Crawler Sage",
        "icon": "$(list-tree)"
      },
      {
        "command": "crawlerSage.refresh",
        "title": "Refresh",
        "category": "Crawler Sage",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "crawlerSage",
          "title": "Crawler Sage",
          "icon": "assets/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "crawlerSage": [
        {
          "id": "crawlerSage.status",
          "name": "Status"
        },
        {
          "id": "crawlerSage.fileTree",
          "name": "Codebase Tree"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "crawlerSage.generate",
          "when": "view == crawlerSage.status",
          "group": "navigation"
        },
        {
          "command": "crawlerSage.refresh",
          "when": "view == crawlerSage.status",
          "group": "navigation"
        },
        {
          "command": "crawlerSage.viewTree",
          "when": "view == crawlerSage.fileTree",
          "group": "navigation"
        },
        {
          "command": "crawlerSage.refresh",
          "when": "view == crawlerSage.fileTree",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Crawler Sage",
      "properties": {
        "crawlerSage.watchEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Automatically regenerate context when files change"
        },
        "crawlerSage.debounceMs": {
          "type": "number",
          "default": 2000,
          "description": "Debounce delay (ms) before regenerating after file changes"
        },
        "crawlerSage.outputFile": {
          "type": "string",
          "default": ".context.md",
          "description": "Output file name for the lean context summary"
        },
        "crawlerSage.outputStyle": {
          "type": "string",
          "default": "xml",
          "enum": ["xml", "markdown", "plain"],
          "description": "Repomix output style — XML is most machine-readable for agents"
        },
        "crawlerSage.compress": {
          "type": "boolean",
          "default": true,
          "description": "Use Tree-sitter compression (~70% token reduction)"
        },
        "crawlerSage.excludePatterns": {
          "type": "array",
          "default": ["node_modules", ".git", "dist", "build", ".context.md"],
          "items": { "type": "string" },
          "description": "Patterns to exclude from file watching"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "npm run compile -- --watch",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
